# Compilatio instrumentorum ddiff et dpatch

PREFIX = /opt/apotheca

omnia: ddiff dpatch

ddiff: ddiff.o
	ldi $^

dpatch: dpatch.o
	ldi $^

%.o: %.c
	ccc $<

proba: omnia
	./proba_prima.py

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 ddiff dpatch $(PREFIX)/bin/

purga:
	rm -f ddiff dpatch ddiff.o dpatch.o

linte:
	insinulint -c ddiff.c dpatch.c

.PHONY: omnia colloca purga proba linte
